# Alias
alias ll "eza -al --git --icons --time-style relative"
alias lla "ll -a"
alias lg "lazygit"
alias rm "gomi"

function cd
  builtin cd $argv
  if type -q eza
    lla
  else
    ls -al
  end
end

# Paths
#   * uv
fish_add_path "{{ .chezmoi.homeDir }}/.local/bin"
#   * Homebrew
{{ if eq .chezmoi.os "linux" }}
test -d ~/.linuxbrew; and eval (~/.linuxbrew/bin/brew shellenv)
test -d /home/linuxbrew/.linuxbrew; and eval (/home/linuxbrew/.linuxbrew/bin/brew shellenv)
{{ end }}

# Environment Variables
set -gx theme_color_scheme "Catppuccin Macchiato"
set -gx XDG_CONFIG_HOME ~/.config
set fzf_preview_dir_cmd lla --color=always
set fzf_fd_opts --no-ignore
set fzf_diff_highlighter delta --paging=never --width=20
set fzf_history_time_format %a %Y-%m-%d %H:%M
set -gx GHQ_SELECTOR fzf
set -gx EZA_CONFIG_DIR ~/.config/eza
set -gx CLAUDE_CONFIG_DIR ~/.config/claude

set -gx FZF_DEFAULT_OPTS "\
--color=bg+:#363A4F,bg:#24273A,spinner:#F4DBD6,hl:#ED8796 \
--color=fg:#CAD3F5,header:#ED8796,info:#C6A0F6,pointer:#F4DBD6 \
--color=marker:#B7BDF8,fg+:#CAD3F5,prompt:#C6A0F6,hl+:#ED8796 \
--color=selected-bg:#494D64 \
--color=border:#6E738D,label:#CAD3F5"

# Setup Tools
command -v starship > /dev/null; and starship init fish | source
if type -q fzf_configure_bindings
    fzf_configure_bindings --directory=\cf --git_log=\cl --git_status=\cs --processes=\cp
end
